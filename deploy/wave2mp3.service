[Unit]
Description=Wave2MP3 — WAV session merger and converter
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Projects/Wave2Mp3
ExecStart=/root/Projects/Wave2Mp3/venv/bin/python main.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
